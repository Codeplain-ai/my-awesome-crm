{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/load-integration-context.sh\"",
            "timeout": 20,
            "statusMessage": "Loading ***plain reference + integration context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-incremental-authoring.sh\"",
            "timeout": 20,
            "statusMessage": "Checking per-question write rule"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_AFK_TIMEOUT_MS": 2147483647
  }
}
